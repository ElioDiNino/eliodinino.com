{
  "name": "eliodinino.com",
  "version": "4.0",
  "private": true,
  "description": "Elio Di Nino's personal website",
  "author": "Elio Di Nino",
  "homepage": "https://eliodinino.com",
  "packageManager": "pnpm@11.1.3",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "test": "cypress run",
    "test:visual": "cypress run --spec cypress/e2e/visual.cy.ts",
    "test:visual:generate": "pnpm run test:visual --env visualRegressionType=base",
    "test:interactive": "cypress open"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/overpass-mono": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@matt-block/react-recaptcha-v2": "^2.2.1",
    "@mui/icons-material": "^9.1.0",
    "@mui/material": "^9.1.0",
    "@plausible-analytics/tracker": "^0.4.5",
    "@sentry/react": "^10.56.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-responsive": "^10.0.1",
    "react-router": "^7.17.0",
    "typeit-react": "^2.7.8",
    "typescript": "^6.0.3",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cypress": "^15.16.0",
    "cypress-visual-regression": "^5.3.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "last 2 versions"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
